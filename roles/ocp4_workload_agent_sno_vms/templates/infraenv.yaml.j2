apiVersion: agent-install.openshift.io/v1beta1
kind: InfraEnv
metadata:
  name: infraenv-{{ _cluster_name }}
  namespace: {{ ocp4_workload_agent_sno_vms_namespace }}
  labels:
    cluster-name: {{ _cluster_name }}
    workload: agent-sno-vms
    workshop: {{ ocp4_workload_agent_sno_vms_workshop_name }}
spec:
  agentLabels:
    cluster-name: {{ _cluster_name }}
  pullSecretRef:
    name: pullsecret-{{ _cluster_name }}
  sshAuthorizedKey: {{ ocp4_workload_agent_sno_vms_ssh_public_key }}
  nmStateConfigLabelSelector:
    matchLabels:
      cluster-name: {{ _cluster_name }}
